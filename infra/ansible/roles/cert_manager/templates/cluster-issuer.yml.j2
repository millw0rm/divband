---
apiVersion: cert-manager.io/v1
kind: ClusterIssuer
metadata:
  name: {{ cert_manager_cluster_issuer }}
  labels:
    app.kubernetes.io/managed-by: ansible
    app.kubernetes.io/part-of: divband
spec:
  acme:
    email: {{ cert_manager_acme_email }}
    server: {{ cert_manager_acme_server }}
    privateKeySecretRef:
      name: {{ cert_manager_private_key_secret_name }}
    solvers:
      - http01:
          ingress:
            class: {{ cert_manager_http01_ingress_class }}
